# ════════════════════════════════════════════════════════════════
# VIVO Backend — variables de entorno
# Copia este archivo a .env y llena los valores reales.
# Las opcionales solo se necesitan en producción.
# ════════════════════════════════════════════════════════════════

# ── Postgres (Railway) ────────────────────────────────────
# Railway lo expone como ${{Postgres.DATABASE_URL}} en el panel
DATABASE_URL=postgresql://USUARIO:PASSWORD@HOST:PUERTO/railway

# ── Auth ──────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_64_chars_random

# ── App ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── CORS / URLs ───────────────────────────────────────────
# Si tienes varios frontends, sepáralos con coma:
FRONTEND_URL=http://localhost:3001,https://vivocargo.com
BACKEND_URL=http://localhost:4000

# ── Cron jobs ─────────────────────────────────────────────
# Si pones false, los crons no arrancan (útil en local)
ENABLE_CRON=false
CRON_TZ=America/Mexico_City

# ════════════════════════════════════════════════════════════════
# API Keys de terceros — BYOK desde la UI (NO aquí)
# ════════════════════════════════════════════════════════════════
# Las API keys de Anthropic, Twilio, SendGrid, Facturama y Mapbox
# se gestionan desde Configuración → API Keys en la app (encriptadas
# en la DB). NO las pongas en .env.
